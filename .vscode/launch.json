{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Next.js Client",
      "type": "chrome",
      "request": "attach",
      "port": 9222,
      "pathMapping": {
        "/": "${workspaceFolder}/UI/",
        "/_next": "${workspaceFolder}/UI/.next"
      }
    },
    {
      "name": "Next.js Server",
      "type": "node",
      "request": "attach",
      "port": 9229,
      "skipFiles": ["<node_internals>/**"]
    }
  ],
  "compounds": [
    {
      "name": "Next.js Full Debug",
      "configurations": ["Next.js Server", "Next.js Client"]
    }
  ]
}
