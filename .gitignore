# macOS
.DS_Store
.AppleDouble
.LSOverride

# VS Code — ignore user-specific files but keep shared project config
.vscode/*
!.vscode/launch.json
!.vscode/tasks.json
!.vscode/extensions.json
.history/

# Node
node_modules/
pm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
package-lock.json

# npm cache
.npm/
.npmrc

# Next.js / Vite / frontend build
.next/
out/
.build/
build/
dist/

# Certificates / keys
*.pem

# pnpm
.pnpm

# ASP.NET / .NET
bin/
obj/
appsettings.Development.json
appsettings.Local.json
*.user
*.suo
*.userosscache
*.sln.docstates
*.vs/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# Environment files
.env
.env.*
.env.local
.env.docker
.env.development.local
.env.test.local
.env.production.local
infra/.env
infra/.env.prod

# Temporary files
*.tmp
*.temp
~*
*.swp
*.swo

# Debug and profiler files
*.pid
*.seed

# Generated test results
TestResults/
coverage/

# JetBrains
.idea/
*.iml

# OS generated files
Thumbs.db
ehthumbs.db

# Local development DB / cache
db.sqlite
*/db.sqlite

# Optional: ignore service and frontend build output
Service/ByteAI.Api/bin/
Service/ByteAI.Api/obj/
UI/.next/
UI/node_modules/

# AI model files — too large for git, download separately
Service/ByteAI.Api/models/

# Xcode — per-user UI state, changes on every open
*.xcuserstate
xcuserdata/

# Terraform — secrets and generated state files, never commit
infra/terraform/terraform.tfvars
infra/terraform/.terraform/
infra/terraform/.terraform.lock.hcl
infra/terraform/*.tfstate
infra/terraform/*.tfstate.backup
infra/terraform/crash.log
