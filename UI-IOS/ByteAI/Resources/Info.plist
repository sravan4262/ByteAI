<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDisplayName</key>
	<string>ByteAI</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>1.0</string>
	<key>CFBundleVersion</key>
	<string>1</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>UIApplicationSceneManifest</key>
	<dict>
		<key>UIApplicationSupportsMultipleScenes</key>
		<false/>
	</dict>
	<!-- Supabase project URL + anon key, injected from xcconfig / scheme env -->
	<key>SupabaseURL</key>
	<string>$(SUPABASE_URL)</string>
	<key>SupabaseAnonKey</key>
	<string>$(SUPABASE_ANON_KEY)</string>
	<!-- Local network access (iOS 14+ to reach LAN backend in dev) -->
	<key>NSLocalNetworkUsageDescription</key>
	<string>ByteAI needs local network access to connect to the development backend.</string>
	<key>NSBonjourServices</key>
	<array>
		<string>_http._tcp</string>
	</array>
	<!-- Photo library access for avatar uploads -->
	<key>NSPhotoLibraryUsageDescription</key>
	<string>ByteAI needs access to your photo library so you can choose a profile picture.</string>
	<!-- Allow plain HTTP to localhost for local dev -->
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsLocalNetworking</key>
		<true/>
		<key>NSAllowsArbitraryLoadsInWebContent</key>
		<false/>
		<key>NSAllowsArbitraryLoads</key>
		<true/>
	</dict>
	<!-- Google Sign-In iOS client ID. Picked up automatically by GoogleSignIn SDK
	     when GIDSignIn.configuration is not set programmatically.
	     Format: <number>-<hash>.apps.googleusercontent.com -->
	<key>GIDClientID</key>
	<string>$(GOOGLE_IOS_CLIENT_ID)</string>
	<!-- URL schemes:
	     - "byteai"             — GitHub OAuth callback (still goes through Supabase)
	     - reversed iOS client  — required by GoogleSignIn SDK fallback path -->
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>byteai</string>
			</array>
			<key>CFBundleURLName</key>
			<string>com.byteai.auth</string>
		</dict>
		<dict>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>com.googleusercontent.apps.604471779766-m33f269r5ha8lm5pk7b3di50rnnuafhg</string>
			</array>
			<key>CFBundleURLName</key>
			<string>com.byteai.googlesignin</string>
		</dict>
	</array>
	<!-- Background modes for push notifications -->
	<key>UIBackgroundModes</key>
	<array>
		<string>remote-notification</string>
	</array>
	<key>UILaunchScreen</key>
	<dict/>
	<key>UIRequiredDeviceCapabilities</key>
	<array>
		<string>armv7</string>
	</array>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
	</array>
</dict>
</plist>
