// ─────────────────────────────────────────────────────────────────────────────
// Release.xcconfig — PRODUCTION BUILD CONFIG
//
// Real values are injected by GitHub Actions (ios.testflight.yml) which writes
// directly into Info.plist before xcodebuild runs, so this file's placeholder
// values are never used in CI builds.
//
// For a manual local release build (rare), set real values here or use the
// test-release-build.sh script which injects them via environment variables.
// ─────────────────────────────────────────────────────────────────────────────

BYTEAI_API_URL = REPLACE_ME_BY_CI
SUPABASE_URL = REPLACE_ME_BY_CI
SUPABASE_ANON_KEY = REPLACE_ME_BY_CI
BYTEAI_SHARE_BASE_URL = https://www.byteaiofficial.com
GOOGLE_IOS_CLIENT_ID = REPLACE_ME_BY_CI
// Reversed iOS client ID — only consulted by xcodebuild's $(...) substitution
// in Info.plist if CI doesn't pre-rewrite the URL types entry. The TestFlight
// workflow always overwrites that entry directly, so this value is unused in
// CI builds; keep the placeholder for parity with manual Release builds.
GOOGLE_IOS_REVERSED_CLIENT_ID = REPLACE_ME_BY_CI
GOOGLE_WEB_CLIENT_ID = REPLACE_ME_BY_CI

// ─── Info.plist preprocessor ────────────────────────────────────────────────
// Release builds intentionally do NOT define BYTEAI_DEBUG, so #ifdef BYTEAI_DEBUG
// blocks in Info.plist (NSAppTransportSecurity, NSLocalNetworkUsageDescription,
// NSBonjourServices) are stripped — production binaries are fully ATS-compliant
// and never declare a local-network purpose string.
// -traditional-cpp prevents the C preprocessor from mangling URLs that contain
// // or /* ... */ inside <string> values.
INFOPLIST_PREPROCESS = YES
INFOPLIST_OTHER_PREPROCESSOR_FLAGS = $(inherited) -traditional-cpp
