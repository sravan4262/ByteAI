{
  "AllowedHosts": "*",
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    }
  },
  "Clerk": {
    "Authority": "${CLERK_AUTHORITY}",
    "WebhookSecret": "${CLERK_WEBHOOK_SECRET}"
  },
