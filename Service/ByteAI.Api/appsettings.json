{
  "AllowedHosts": "*",
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {SourceContext}: {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  },
  "Cors": {
    "AllowedOrigin": "http://localhost:3000"
  },
  "ConnectionStrings": {
    "Postgres": ""
  },
  "Groq": {
    "ApiKey": "",
    "Model": "llama-3.3-70b-versatile"
  },
  "Ai": {
    "OnnxModelPath": "models/nomic-embed-text-v1.5.onnx",
    "VocabPath": "models/vocab.txt"
  },
  "Supabase": {
    "Url": "",
    "JwtSecret": "",
    "ServiceRoleKey": "",
    "AvatarBucket": "byteAIAvatars"
  }
}
