{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "ByteAI": "Debug"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {SourceContext}: {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  },
  "Clerk": {
    "Authority": "https://<your-clerk-dev-instance>.clerk.accounts.dev",
    "WebhookSecret": "whsec_<your-dev-webhook-secret>"
  },
  "Cors": {
    "AllowedOrigin": "http://localhost:3000"
  },
  "ConnectionStrings": {
    "Postgres": "Host=postgres;Port=5432;Database=byteai;Username=byteai;Password=byteai"
  },
  "Groq": {
    "ApiKey": "gsk_<your-groq-api-key>"
  },
  "Ai": {
    "OnnxModelPath": "models/nomic-embed-text-v1.5.onnx",
    "VocabPath": "models/vocab.txt"
  },
  "Supabase": {
    "Url": "https://<your-project>.supabase.co",
    "ServiceRoleKey": "<supabase-service-role-key>",
    "AvatarBucket": "byteAIAvatars"
  }
}
